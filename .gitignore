.DS_Store

# Real local profiles with private proxy credentials.
trojan/pc.yaml
trojan/ios.yaml
trojan/*.local.yaml
trojan/*.private.yaml

# Local proxy-provider files contain private nodes. Keep examples public.
trojan/proxy_providers/*.yaml
!trojan/proxy_providers/*.example.yaml

# Runtime-downloaded rule providers.
trojan/ruleset/

# Real Stash override files can contain private proxy credentials.
ios/personal-node.stoverride
ios/*.local.stoverride
ios/*.private.stoverride

# Runtime-downloaded iOS rule providers.
ios/ruleset/
